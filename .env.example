# ============================================================
# IDVision Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Database
DATABASE_URL=postgresql+asyncpg://idvision:your_secure_password@db:5432/idvision
DB_PASSWORD=your_secure_password

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_group_chat_id

# Face Recognition
SIMILARITY_THRESHOLD=0.55
ANTI_SPOOFING_ENABLED=true
LIVENESS_THRESHOLD=0.5

# Attendance Rules
LATE_THRESHOLD_HOUR=8
LATE_THRESHOLD_MINUTE=0
DUPLICATE_CHECK_MINUTES=30

# Camera Configuration
CAMERA_SOURCE=0
# For RTSP: CAMERA_SOURCE=rtsp://user:pass@192.168.1.100:554/stream

# Backend URL (used by AI service)
BACKEND_URL=http://backend:8000
